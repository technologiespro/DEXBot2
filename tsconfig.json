{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node16",
    "types": ["node"],
    "allowJs": false
  },
  "include": [
    "modules/**/*.ts",
    "market_adapter/**/*.ts",

    "scripts/**/*.ts",
    "analysis/**/*.ts",
    "dexbot.ts",
    "bot.ts",
    "pm2.ts",
    "unlock-start.ts",
    "credential-daemon.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "dashboard",
    "profiles"
  ]
}
