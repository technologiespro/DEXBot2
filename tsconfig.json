{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noImplicitThis": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "allowJs": false
  },
  "include": [
    "modules/**/*.ts",
    "market_adapter/**/*.ts",
    "claw/**/*.ts",
    "scripts/**/*.ts",
    "analysis/**/*.ts",
    "dexbot.ts",
    "bot.ts",
    "pm2.ts",
    "unlock-start.ts",
    "credential-daemon.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "dashboard",
    "profiles"
  ]
}
