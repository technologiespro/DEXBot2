{
  "name": "dexbot2-claw",
  "version": "0.7.16",
  "private": true,
  "description": "Claw bridge and runtime integration layer for BitShares and DEXBot2.",
  "type": "commonjs",
  "main": "index.js",
  "peerDependencies": {
    "openclaw": ">=2026.3.27"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./runtimes/openclaw-plugin/index.js"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "example:connection": "npm run build && node ../dist/claw/examples/connection_test.js",
    "example:claw-infra": "npm run build && node ../dist/claw/examples/claw_infra_example.js",
    "example:claw-consumer": "npm run build && node ../dist/claw/examples/claw_consumer_example.js",
    "example:claw-profiles": "npm run build && node ../dist/claw/examples/claw_profiles_example.js",
    "example:honest-ecosystem": "npm run build && node ../dist/claw/examples/honest_ecosystem_example.js",
    "example:nullclaw-bridge": "npm run build && node ../dist/claw/examples/nullclaw_bridge_example.js",
    "example:zeroclaw-bridge": "npm run build && node ../dist/claw/examples/zeroclaw_bridge_example.js",
    "example:memu-integration": "npm run build && node ../dist/claw/examples/memu_integration_example.js",
    "example:position-manager": "npm run build && node ../dist/claw/examples/position_manager_cli.js",
    "example:short-mpa-bts": "npm run build && node ../dist/claw/examples/short_mpa_bts_strategy.js",
    "claw:bridge": "npx tsx scripts/claw_bridge.ts",
    "claw:mcp": "npx tsx scripts/claw_mcp_server.ts",
    "claw:skill": "npx tsx scripts/claw_skill_md.ts",
    "hermes:skill": "npx tsx scripts/claw_skill_md.ts --runtime hermes",
    "openfang:bridge": "npx tsx scripts/openfang_bridge.ts",
    "openfang:skill": "npx tsx scripts/claw_skill_md.ts --runtime openfang",
    "nanobot:skill": "npx tsx scripts/claw_skill_md.ts --runtime nanobot",
    "nanoclaw:bridge": "npx tsx scripts/nanoclaw_bridge.ts",
    "nanoclaw:skill": "npx tsx scripts/claw_skill_md.ts --runtime nanoclaw",
    "picoclaw:skill": "npx tsx scripts/claw_skill_md.ts --runtime picoclaw",
    "openclaw:skill": "npx tsx scripts/claw_skill_md.ts --runtime openclaw",
    "nullclaw:bridge": "npx tsx scripts/nullclaw_bridge.ts",
    "nullclaw:skill": "npx tsx scripts/nullclaw_skill.ts",
    "zeroclaw:bridge": "npx tsx scripts/zeroclaw_bridge.ts",
    "zeroclaw:skill": "npx tsx scripts/zeroclaw_skill.ts",
    "memu:bridge": "npx tsx scripts/memu_mcp_server.ts",
    "memu:mcp": "npx tsx scripts/memu_mcp_server.ts",
    "memu:skill": "npx tsx scripts/claw_skill_md.ts --runtime memu",
    "memu:status": "npm run build && node -e \"const {runMemuCommand}=require('../dist/claw/modules/memu_bridge.js');runMemuCommand('status').then(r=>console.log(JSON.stringify(r,null,2))).catch(e=>console.error(e.message))\"",
    "service:position-watch": "npm run build && node ../dist/claw/modules/position_manager_watch.js",
    "pm2:start": "npm run build && pm2 start ../dist/claw/ecosystem.config.js",
    "pm2:stop": "pm2 stop ../dist/claw/ecosystem.config.js",
    "report:honest-assets": "npx tsx scripts/honest_assets_report.ts",
    "test": "npm run build && node ../dist/claw/tests/test_claw_regressions.js && node ../dist/claw/tests/test_claw_state_store.js && node ../dist/claw/tests/test_dexbot_profiles.js && node ../dist/claw/tests/test_position_manager_watch_health.js && node ../dist/claw/tests/test_claw_bridge.js && node ../dist/claw/tests/test_memu_bridge.js && node ../dist/claw/tests/test_short_mpa_strategy.js && node ../dist/claw/tests/test_position_health.js && node ../dist/claw/tests/test_claw_chain_layer.js && node ../dist/claw/tests/test_claw_domain_logic.js && node ../dist/claw/tests/test_claw_catalog_and_credentials.js && node ../dist/claw/tests/test_claw_data_flow.js && node ../dist/claw/tests/test_position_manager.js && node ../dist/claw/tests/test_claw_skill_generation.js && node ../dist/claw/tests/test_claw_manifest_and_matrix.js && node ../dist/claw/tests/test_claw_mcp_transport.js && node ../dist/claw/tests/test_nullclaw_tmp_integration.js",
    "check": "npm run build && node -e \"require('./index.js')\" && node -c ../dist/claw/ecosystem.config.js && node -c ../dist/claw/runtimes/openclaw-plugin/index.js"
  }
}
